# Local init example (create your S3 bucket + DynamoDB lock table first):
#   terraform init -backend-config=backend.hcl
#
# bucket         = "your-terraform-state-bucket"
# key            = "terraform-basic-project/terraform.tfstate"
# region         = "us-east-1"
# dynamodb_table = "terraform-locks"
# encrypt        = true

bucket         = "CHANGE_ME-terraform-state"
key            = "terraform-basic-project/terraform.tfstate"
region         = "us-east-1"
dynamodb_table = "terraform-locks"
encrypt        = true
