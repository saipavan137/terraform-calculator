# ── GCP extension (optional) ────────────────────────────────────────────────
# Azure is wired in azure.tf. For GCP only:
#   copy multi_cloud.tf.example multi_cloud.tf
#   copy providers.gcp.tf.example providers.gcp.tf
#   terraform init -upgrade
#   set enable_gcp = true in terraform.tfvars

terraform {
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 6.0"
    }
  }
}

module "gcp_app" {
  count  = var.enable_gcp && var.gcp_project_id != "" ? 1 : 0
  source = "./modules/gcp_node_web"

  project_id    = var.gcp_project_id
  region        = var.gcp_region
  zone          = var.gcp_zone
  name_prefix   = var.gcp_name_prefix
  machine_type  = var.gcp_machine_type
  instance_name = var.gcp_instance_name
  app_port      = var.app_port
}
