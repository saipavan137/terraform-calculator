# Copy to terraform.tfvars and fill in your values:
#   copy terraform.tfvars.example terraform.tfvars

# Cloud toggles — turn on each provider you have credentials for:
enable_aws   = true
enable_azure = false

# Azure only example:
# enable_aws   = false
# enable_azure = true

# AWS + Azure together:
# enable_aws = true
# enable_azure = true

app_port = 80

# AWS — configure: aws configure  (or AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)
aws_region        = "us-east-1"
aws_ami           = "ami-05ffe3c48a9991133"
aws_instance_type = "t2.micro"

# Azure — configure: az login  (or AZURE_CREDENTIALS / ARM_* in CI)
azure_subscription_id = "your-azure-subscription-id"
azure_location        = "westus2"
azure_name_prefix     = "tf-calc"
# azure_admin_password = "Change-Me-StrongPass1!"  # optional; has a default for demos
