output "azure_app_url" {
  description = "Calculator URL on Azure (null if disabled)."
  value       = var.enable_azure ? module.azure_app[0].app_url : null
}

output "gcp_app_url" {
  description = "Calculator URL on GCP (null if disabled)."
  value       = var.enable_gcp && var.gcp_project_id != "" ? module.gcp_app[0].app_url : null
}

output "calculator_urls" {
  description = "All active calculator URLs by cloud."
  value = {
    aws   = var.enable_aws ? module.aws_app[0].app_url : null
    azure = var.enable_azure ? module.azure_app[0].app_url : null
    gcp   = var.enable_gcp && var.gcp_project_id != "" ? module.gcp_app[0].app_url : null
  }
}

output "azure_public_ip" {
  description = "Azure VM public IP."
  value       = var.enable_azure ? module.azure_app[0].public_ip : null
}

output "gcp_public_ip" {
  description = "GCP VM public IP."
  value       = var.enable_gcp && var.gcp_project_id != "" ? module.gcp_app[0].public_ip : null
}
